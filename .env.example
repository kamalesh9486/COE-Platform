# Copy this file to .env.local and fill in your Power Automate endpoint URLs
# .env.local is git-ignored — never commit real signing tokens

VITE_AGENT_ENDPOINT=https://<env>.environment.api.powerplatform.com/...&sig=<token>
VITE_COPILOT_ENDPOINT=https://<env>.environment.api.powerplatform.com/...&sig=<token>
